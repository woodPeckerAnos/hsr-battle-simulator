{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "enemy.schema.json",
  "type": "object",
  "required": ["id", "name", "level", "defense", "hp", "toughness"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "level": { "type": "integer" },
    "element": { "type": "string" },
    "weaknesses": { "type": "array", "items": { "type": "string" } },
    "defense": { "type": "number" },
    "hp": { "type": "number" },
    "toughness": { "type": "number" },
    "speed": { "type": "number" },
    "resistances": { "type": "object" },
    "effectRes": { "type": "number" },
    "passive": { "type": "boolean", "description": "木桩：不行动、不加入行动轴" }
  }
}
